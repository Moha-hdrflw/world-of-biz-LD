---
const CALENDLY = "https://calendly.com/francereussiterdv/30min?month=2026-04";
---
<section class="final">
  <div class="final-glow-blue"></div>
  <div class="final-glow-blue2"></div>

  <div class="container final-content">
    <div class="final-badge">
      <span class="stars">★★★★★</span>
      <span>5/5 sur Google</span>
    </div>

    <h2 class="final-title">
      <span class="t-white">Prêt(e) à décrocher</span><br />
      <span class="t-white">ton permis ?</span>
    </h2>

    <p class="final-desc">
      Un appel gratuit, 10 minutes, et tu sais exactement comment procéder.
      Nos conseillers sont disponibles maintenant.
    </p>

    <a href={CALENDLY} target="_blank" rel="noopener noreferrer" class="btn-cta final-btn" onclick="fbq('track', 'Lead')">
      Je réserve mon appel gratuit →
    </a>

    <p class="final-trust">Gratuit · Sans engagement · Réponse rapide</p>

    <div class="final-checks">
      <span>✅ Paiement 3x ou 4x sans frais</span>
      <span>✅ Éligible CPF (Permis B)</span>
      <span>✅ Moniteurs certifiés</span>
      <span>✅ Paris 19ème</span>
    </div>
  </div>
</section>

<style>
  .final {
    position: relative;
    padding: 80px 0;
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    text-align: center;
    overflow: hidden;
  }

  .final-glow-blue {
    position: absolute;
    top: -120px; right: -80px;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(42,126,245,0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .final-glow-blue2 {
    position: absolute;
    bottom: -80px; left: -60px;
    width: 360px; height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(42,126,245,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .final-content { position: relative; z-index: 1; }

  .final-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    padding: 7px 16px;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--card-text);
    margin-bottom: 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .stars { color: #F4B942; }

  .final-title {
    font-size: clamp(2.6rem, 11vw, 4.5rem);
    line-height: 1.05;
    margin-bottom: 18px;
  }

  .t-white {
    color: var(--white);
    text-shadow: 0 0 20px rgba(255,255,255,0.2);
  }

  .t-blue {
    color: var(--blue);
    text-shadow:
      0 0 20px rgba(42,126,245,0.9),
      0 0 60px rgba(42,126,245,0.45),
      0 0 100px rgba(42,126,245,0.2);
  }

  .final-desc {
    font-size: 1rem;
    color: var(--text-soft);
    max-width: 460px;
    margin: 0 auto 28px;
    line-height: 1.65;
  }

  .final-btn { font-size: 1.1rem; padding: 20px 32px; margin-bottom: 14px; }

  .final-trust {
    font-size: 0.78rem;
    color: var(--text-soft);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
  }

  .final-checks {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 20px;
  }

  .final-checks span { font-size: 0.85rem; font-weight: 600; color: var(--text-soft); }
</style>
