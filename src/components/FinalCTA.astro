---
const CALENDLY = "https://calendly.com/worldofbizaxion/15min?month=2026-05";
---
<section class="final">
  <div class="final-glow-blue"></div>
  <div class="final-glow-blue2"></div>

  <div class="container final-content">
    <img src="/logo-wob.webp" alt="World of Biz" class="final-logo" />

    <h2 class="final-title">
      <span class="t-white">Prêt(e) à décrocher</span><br />
      <span class="t-white">ton permis ?</span>
    </h2>

    <a href={CALENDLY} target="_blank" rel="noopener noreferrer" class="btn-cta final-btn" onclick="fbq('track', 'Lead')">
      Je réserve mon appel gratuit →
    </a>

    <p class="final-trust">Gratuit · Sans engagement · Réponse rapide</p>

    <div class="final-agencies">
      <p class="agencies-title">Nos agences</p>
      <ul class="agencies-list">
        <li><span class="agency-city">Pierrefitte-sur-Seine</span><span class="agency-addr">2 Rue Armand Brette, 93380 Pierrefitte-sur-Seine</span></li>
        <li><span class="agency-city">Tonnerre</span><span class="agency-addr">10 place Charles de Gaulle, 89700 Tonnerre</span></li>
        <li><span class="agency-city">Drancy</span><span class="agency-addr">215 avenue Jean Jaurès, 93700 Drancy</span></li>
        <li><span class="agency-city">Les Pavillons-sous-Bois</span><span class="agency-addr">66 allée Émile Zola, 93320 Les Pavillons-sous-Bois</span></li>
      </ul>
    </div>
  </div>
</section>

<style>
  .final {
    position: relative;
    padding: 80px 0;
    background: var(--bg-alt);
    border-top: 1px solid var(--border);
    text-align: center;
    overflow: hidden;
  }

  .final-glow-blue {
    position: absolute;
    top: -120px; right: -80px;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .final-glow-blue2 {
    position: absolute;
    bottom: -80px; left: -60px;
    width: 360px; height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .final-content { position: relative; z-index: 1; }

  .final-logo {
    height: 120px;
    width: auto;
    object-fit: contain;
    margin: 0 auto 28px;
  }

  .final-title {
    font-size: clamp(2.6rem, 11vw, 4.5rem);
    line-height: 1.05;
    margin-bottom: 18px;
  }

  .t-white {
    color: var(--white);
    text-shadow: 0 0 20px rgba(255,255,255,0.2);
  }

  .t-blue {
    color: var(--blue);
    text-shadow:
      0 0 20px rgba(42,126,245,0.9),
      0 0 60px rgba(42,126,245,0.45),
      0 0 100px rgba(42,126,245,0.2);
  }

  .final-desc {
    font-size: 1rem;
    color: var(--text-soft);
    max-width: 460px;
    margin: 0 auto 28px;
    line-height: 1.65;
  }

  .final-btn { font-size: 1.1rem; padding: 20px 32px; margin-bottom: 14px; }

  .final-trust {
    font-size: 0.78rem;
    color: var(--text-soft);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 32px;
  }

  .final-agencies {
    background: rgba(201,168,76,0.06);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 8px;
    padding: 20px 24px;
    text-align: left;
  }

  .agencies-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--gold);
    margin-bottom: 14px;
  }

  .agencies-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .agencies-list li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .agency-city {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--text);
  }

  .agency-addr {
    font-size: 0.82rem;
    color: var(--text-soft);
  }
</style>
