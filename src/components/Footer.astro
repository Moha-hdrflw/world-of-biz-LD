---
const CALENDLY = "https://calendly.com/worldofbizaxion/15min?month=2026-05";
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src="/logo-wob.webp" alt="World of Biz" class="footer-logo" />
      <div>
        <div class="footer-name">World of Biz</div>
        <div class="footer-sub">École de Conduite</div>
      </div>
    </div>

    <div class="footer-info">
      <a href={CALENDLY} target="_blank" rel="noopener noreferrer" class="footer-link" onclick="fbq('track', 'Lead')">
        Réserver un appel gratuit →
      </a>
    </div>

    <p class="footer-copy">© {year} World of Biz — Tous droits réservés</p>
  </div>
</footer>

<style>
  .footer {
    background: #0A0A0A !important;
    border-top: 1px solid rgba(201,168,76,0.2);
    padding: 40px 0;
    color: rgba(245,230,180,0.5);
  }

  .footer-inner { display: flex; flex-direction: column; gap: 20px; }

  .footer-brand { display: flex; align-items: center; gap: 12px; }

  .footer-logo { height: 44px; width: auto; object-fit: contain; }

  .footer-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    text-transform: uppercase;
    color: var(--gold);
    line-height: 1;
  }

  .footer-sub { font-size: 0.72rem; color: rgba(245,230,180,0.4); margin-top: 2px; }

  .footer-info { display: flex; flex-direction: column; gap: 6px; font-size: 0.87rem; }

  .footer-link {
    color: var(--gold);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-link:hover { color: var(--white); }

  .footer-copy { font-size: 0.76rem; color: rgba(245,230,180,0.25); }
</style>
