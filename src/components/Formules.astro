---
const CALENDLY = "https://calendly.com/francereussiterdv/30min?month=2026-04";

const formules = [
  {
    badge: "Le plus populaire",
    icon: "🚗",
    name: "Boîte Automatique",
    price: "799€",
    highlight: true,
    features: [
      "13h de conduite dont 2h simulateur",
      "Code de la route inclus",
      "Moniteur dédié et bienveillant",
      "Paiement 3x ou 4x sans frais via Alma",
      "Éligible CPF pour demandeurs d'emploi",
      "Date d'examen rapide",
    ],
    cpf: true,
    ctaLabel: "Je réserve — Boîte Auto →",
  },
  {
    badge: null,
    icon: "🚙",
    name: "Boîte Manuelle",
    price: "799€",
    highlight: false,
    features: [
      "20h de conduite dont 3h simulateur",
      "Code de la route inclus",
      "Moniteur dédié et bienveillant",
      "Paiement 3x ou 4x sans frais via Alma",
      "Éligible CPF pour demandeurs d'emploi",
      "Date d'examen rapide",
    ],
    cpf: true,
    ctaLabel: "Je réserve — Boîte Manuelle →",
  },
  {
    badge: null,
    icon: "🏍️",
    name: "Permis Moto A2",
    price: "750€",
    highlight: false,
    features: [
      "Formation complète plateau & circulation",
      "ETG (code) inclus",
      "Moniteurs moto certifiés",
      "Paiement en plusieurs fois via Alma",
      "⚠️ Non éligible CPF",
      "Date d'examen rapide",
    ],
    cpf: false,
    ctaLabel: "Je réserve — Permis Moto →",
  },
];
---
<section class="formules">
  <div class="container">
    <span class="section-label">Nos formules</span>
    <h2 class="formules-title">Choisis ta formule</h2>
    <p class="formules-sub">Toutes nos formules incluent un suivi personnalisé par nos moniteurs certifiés.</p>

    <div class="cards">
      {formules.map((f) => (
        <div class={`card ${f.highlight ? 'card-highlight' : ''}`}>
          {f.badge && <div class="card-badge">{f.badge}</div>}
          <div class="card-icon">{f.icon}</div>
          <h3 class="card-name">{f.name}</h3>
          <div class="card-price">{f.price}</div>
          {f.cpf && (
            <div class="cpf-tag">✅ Éligible CPF</div>
          )}
          <ul class="card-features">
            {f.features.map((feat) => (
              <li>
                <span class="feat-check">✓</span>
                <span>{feat}</span>
              </li>
            ))}
          </ul>
          <a
            href={CALENDLY}
            target="_blank"
            rel="noopener noreferrer"
            class={`btn-cta card-cta ${f.highlight ? '' : 'btn-outline'}`}
            onclick="fbq('track', 'Lead')"
          >
            {f.ctaLabel}
          </a>
        </div>
      ))}
    </div>

    <p class="formules-note">
      💳 Paiement sécurisé via <strong>Alma</strong> — 3x ou 4x sans frais sur les permis B.
    </p>
  </div>
</section>

<style>
  .formules {
    padding: 80px 0;
    background: var(--cream);
  }

  .formules-title {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--text);
    margin-bottom: 10px;
  }

  .formules-sub {
    color: #555;
    font-size: 1rem;
    margin-bottom: 48px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .card {
    background: var(--white);
    border: 2px solid var(--border);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
  }

  .card-highlight {
    border-color: var(--blue);
    box-shadow: 0 4px 24px rgba(30, 95, 168, 0.12);
  }

  .card-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--blue);
    color: var(--white);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 16px;
    clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
    white-space: nowrap;
  }

  .card-icon {
    font-size: 2.2rem;
  }

  .card-name {
    font-size: 1.4rem;
    color: var(--text);
    text-transform: uppercase;
  }

  .card-price {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 2.8rem;
    color: var(--blue);
    line-height: 1;
  }

  .cpf-tag {
    background: rgba(30, 95, 168, 0.08);
    color: var(--blue);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 5px 12px;
    display: inline-block;
  }

  .card-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 4px 0;
  }

  .card-features li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.5;
  }

  .feat-check {
    color: var(--blue);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .card-cta {
    margin-top: auto;
    text-align: center;
  }

  .btn-outline {
    background: transparent;
    color: var(--blue) !important;
    border: 2px solid var(--blue);
  }

  .btn-outline:hover {
    background: var(--blue);
    color: var(--white) !important;
  }

  .formules-note {
    text-align: center;
    margin-top: 36px;
    font-size: 0.92rem;
    color: #666;
  }

  @media (max-width: 900px) {
    .cards {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }

    .card-badge {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 768px) {
    .formules {
      padding: 56px 0;
    }
  }
</style>
