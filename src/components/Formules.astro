---
const CALENDLY = "https://calendly.com/worldofbizaxion/15min?month=2026-05";
const formules = [
  {
    badge: "Le plus populaire",
    name: "Boîte Manuelle Express",
    price: null, monthly: null,
    highlight: true,
    limited: true,
    features: ["20h de conduite — permis en 1 mois","Code de la route inclus","Dates d'examen express — zéro attente","Paiement 3x ou 4x sans frais","Accompagnement du début à la fin"],
    ctaLabel: "Je réserve — Boîte Manuelle →",
  },
  {
    badge: null,
    name: "Boîte Automatique Express",
    price: null, monthly: null,
    highlight: false,
    limited: true,
    features: ["13h de conduite — permis en 1 mois","Code de la route inclus","Dates d'examen express — zéro attente","Paiement 3x ou 4x sans frais","Accompagnement du début à la fin"],
    ctaLabel: "Je réserve — Boîte Auto →",
  },
  {
    badge: null,
    name: "Moto A2 Express",
    price: null, monthly: null,
    highlight: false,
    limited: false,
    features: ["20h de conduite — permis en 1 mois","ETG (code moto) inclus","Formation plateau & circulation accélérée","Moniteurs moto certifiés","Dates d'examen express — zéro attente","Paiement 3x ou 4x sans frais"],
    ctaLabel: "Je réserve — Permis Moto →",
  },
];
---
<section class="formules">
  <div class="container">
    <span class="section-label">Nos offres</span>
    <h2 class="formules-title">
      Choisis ta <span class="accent">formule</span>
    </h2>

    <div class="cards">
      {formules.map((f) => (
        <div class={`card ${f.highlight ? 'card-hi' : ''}`}>
          {f.badge && <div class="card-badge">{f.badge}</div>}
          {f.limited && <div class="card-limited">🔥 Offre &amp; places limitées !</div>}

          <div class="card-header">
            <h3 class="card-name">{f.name}</h3>
            {f.price && <div class="card-price">{f.price}</div>}
            {f.monthly && <p class="card-monthly">Paiement en 3x = <strong>{f.monthly}</strong></p>}
          </div>

          <ul class="feat-list">
            {f.features.map((feat) => (
              <li class="feat-item">
                <span class="feat-check">✅</span>
                <span>{feat}</span>
              </li>
            ))}
          </ul>

          <a href={CALENDLY} target="_blank" rel="noopener noreferrer" class="btn-cta card-btn" onclick="fbq('track', 'Lead')">
            {f.ctaLabel}
          </a>
        </div>
      ))}
    </div>

    <p class="formules-note">💳 Paiement en plusieurs fois sans frais — disponible sur toutes nos formules</p>
  </div>
</section>

<style>
  .formules { padding: 72px 0; background: var(--bg); }

  .formules-title {
    font-size: clamp(2.2rem, 9vw, 3.5rem);
    color: var(--white);
    margin-bottom: 32px;
  }

  .accent {
    color: var(--blue);
    text-shadow: 0 0 20px var(--blue-glow), 0 0 48px rgba(42,126,245,0.2);
  }

  .cards { display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px; }

  .card {
    background: #241F15;
    border: 2px solid rgba(201,168,76,0.5);
    box-shadow:
      0 4px 32px rgba(201,168,76,0.2),
      0 0 40px rgba(201,168,76,0.1);
    border-radius: 8px;
    overflow: hidden;
  }

  .card-hi {
    border-color: rgba(201,168,76,0.9);
    box-shadow:
      0 4px 32px rgba(201,168,76,0.25),
      0 0 40px rgba(201,168,76,0.1);
  }

  .card-badge {
    background: linear-gradient(135deg, #C9A84C 0%, #E8C96A 50%, #C9A84C 100%);
    color: #0A0A0A;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 7px 20px;
    clip-path: polygon(0 0, 100% 0, calc(100% - 8px) 100%, 0% 100%);
    display: inline-block;
    box-shadow: 0 0 14px rgba(201,168,76,0.5);
  }

  .card-limited {
    background: linear-gradient(90deg, rgba(230,57,70,0.12), rgba(230,57,70,0.06));
    border-bottom: 1px solid rgba(230,57,70,0.25);
    color: #c0392b;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 7px 22px;
  }

  .card-header {
    padding: 22px 22px 18px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .card-name {
    font-size: 1.5rem;
    color: var(--card-text);
    margin-bottom: 8px;
  }

  .card-price {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 3.8rem;
    color: #ffffff;
    line-height: 1;
    margin-bottom: 4px;
    text-shadow: none;
  }

  .card-monthly { font-size: 0.85rem; color: var(--card-text-soft); }
  .card-monthly strong { color: var(--card-text); }

  .feat-list { list-style: none; padding: 0 22px; }

  .feat-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 0;
    font-size: 0.93rem;
    color: var(--card-text);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .feat-item:last-child { border-bottom: none; }
  .feat-check { font-size: 1rem; flex-shrink: 0; }

  .card-btn {
    margin: 18px 22px 22px;
    width: calc(100% - 44px);
    font-size: 0.95rem;
    padding: 16px;
  }

  .formules-note {
    text-align: center;
    font-size: 0.88rem;
    color: var(--text-soft);
    padding: 14px;
    background: rgba(201,168,76,0.06);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .formules-note strong { color: var(--text); }
</style>
