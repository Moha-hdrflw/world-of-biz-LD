---
const CALENDLY = "https://calendly.com/worldofbizaxion/15min?month=2026-05";
---
<section class="hero">
  <div class="hero-glow-red"></div>
  <div class="hero-glow-white"></div>
  <div class="hero-glow-red2"></div>
  <div class="hero-glow-white2"></div>

  <div class="container hero-content">

    <img src="/logo-wob.webp" alt="World of Biz" class="hero-logo" />

    <div class="hero-available">
      <span class="dot"></span>
      <span>Conseillers disponibles</span>
    </div>

    <h1 class="hero-title">
      <span class="title-white">Obtiens ton permis en</span><br />
      <span class="title-blue">1 mois !</span>
    </h1>

    <p class="hero-desc">
      Réserve un appel gratuit avec un conseiller. Il répond à toutes tes questions
      et t'accompagne pas à pas, sans pression.
    </p>

    <a
      href={CALENDLY}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-cta hero-btn"
      onclick="fbq('track', 'Lead')"
    >
      Je réserve mon appel gratuit →
    </a>

    <p class="hero-trust">Gratuit · Sans engagement · 7j/7</p>

    <div class="hero-pills">
      <div class="pill">📅 Dates d'examen express</div>
      <div class="pill">💳 Paiement 3x ou 4x sans frais</div>
      <div class="pill">🎓 Moniteurs certifiés</div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--bg);
    padding: 64px 0 56px;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  /* Glows néon fond */
  .hero-glow-red {
    position: absolute;
    top: -60px;
    right: -40px;
    width: 380px;
    height: 380px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.28) 0%, rgba(201,168,76,0.08) 50%, transparent 75%);
    pointer-events: none;
    filter: blur(8px);
  }

  .hero-glow-white {
    position: absolute;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.04) 50%, transparent 75%);
    pointer-events: none;
    filter: blur(12px);
  }

  .hero-glow-red2 {
    position: absolute;
    bottom: 20px;
    left: -60px;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.18) 0%, transparent 70%);
    pointer-events: none;
    filter: blur(6px);
  }

  .hero-glow-white2 {
    position: absolute;
    bottom: -40px;
    right: 20px;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%);
    pointer-events: none;
    filter: blur(10px);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  .hero-logo {
    height: 110px;
    width: auto;
    object-fit: contain;
    border-radius: 12px;
    margin-bottom: 20px;
  }

  .hero-available {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(34,197,94,0.45);
    padding: 8px 18px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(200,255,200,0.85);
    margin-bottom: 24px;
    width: fit-content;
    backdrop-filter: blur(6px);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px #22c55e, 0 0 16px rgba(34,197,94,0.6);
    flex-shrink: 0;
  }

  .hero-title {
    font-size: clamp(3.5rem, 15vw, 7rem);
    line-height: 1;
    margin-bottom: 20px;
  }

  .title-white {
    color: var(--white);
    text-shadow:
      0 0 20px rgba(255,255,255,0.5),
      0 0 50px rgba(255,255,255,0.2);
  }

  .title-blue {
    color: #C9A84C;
    text-shadow:
      0 0 6px rgba(201,168,76,0.7),
      0 0 25px rgba(201,168,76,0.85),
      0 0 55px rgba(201,168,76,0.5),
      0 0 100px rgba(201,168,76,0.2);
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--text-soft);
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 520px;
  }

  .hero-btn {
    font-size: 1.1rem;
    padding: 20px 32px;
    margin-bottom: 14px;
  }

  .hero-trust {
    text-align: center;
    font-size: 0.78rem;
    color: var(--text-soft);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 32px;
  }

  .hero-pills {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pill {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(201,168,76,0.25);
    box-shadow: 0 0 12px rgba(201,168,76,0.08);
    padding: 13px 20px;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    text-align: center;
  }
</style>
