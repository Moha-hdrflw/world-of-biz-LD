---
const CALENDLY = "https://calendly.com/francereussiterdv/30min?month=2026-04";
const steps = [
  { num: "01", icon: "📅", title: "Tu réserves un créneau", desc: "Choisis le jour et l'heure qui te convient. L'appel dure environ 10 minutes." },
  { num: "02", icon: "📞", title: "Un conseiller t'appelle", desc: "Notre équipe est disponible 7j/7. Il répond à toutes tes questions sur la formation, les délais, le paiement." },
  { num: "03", icon: "✅", title: "Tu t'inscris depuis ton téléphone", desc: "Si France Réussite correspond, l'inscription se fait directement. Simple et rapide." },
];
---
<section class="hiw">
  <div class="container">
    <span class="section-label">Simple et rapide</span>
    <h2 class="hiw-title">Comment ça<br/>se passe ?</h2>

    <div class="steps">
      {steps.map((s) => (
        <div class="step-card">
          <div class="step-top">
            <span class="step-icon">{s.icon}</span>
            <span class="step-num">{s.num}</span>
          </div>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-desc">{s.desc}</p>
        </div>
      ))}
    </div>

    <a href={CALENDLY} target="_blank" rel="noopener noreferrer" class="btn-cta" onclick="fbq('track', 'Lead')">
      Je réserve mon appel gratuit →
    </a>
  </div>
</section>

<style>
  .hiw { padding: 72px 0; background: var(--bg-alt); }

  .hiw-title {
    font-size: clamp(2.2rem, 9vw, 3.5rem);
    color: var(--white);
    margin-bottom: 36px;
  }

  .steps { display: flex; flex-direction: column; gap: 14px; margin-bottom: 32px; }

  .step-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow:
      0 4px 20px rgba(0,0,0,0.25),
      0 0 0 1px rgba(42,126,245,0.08),
      0 0 20px rgba(42,126,245,0.06);
    border-radius: 8px;
    padding: 26px 22px;
  }

  .step-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .step-icon { font-size: 2rem; line-height: 1; }

  .step-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 5rem;
    color: #2a7ef5;
    line-height: 1;
    text-shadow:
      0 0 20px rgba(42,126,245,0.9),
      0 0 50px rgba(42,126,245,0.5),
      0 0 90px rgba(42,126,245,0.25);
  }

  .step-title {
    font-size: 1.08rem;
    color: var(--card-text);
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .step-desc { font-size: 0.93rem; color: var(--card-text-soft); line-height: 1.65; }
</style>
