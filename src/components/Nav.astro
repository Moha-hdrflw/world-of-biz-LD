---
const CALENDLY = "https://calendly.com/francereussiterdv/30min?month=2026-04";
---
<nav class="nav">
  <div class="nav-inner">
    <img src="/logo-fr.png" alt="France Réussite" class="nav-logo" />
    <a
      href={CALENDLY}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-cta nav-cta"
      onclick="fbq('track', 'Lead')"
    >
      Réserver mon appel gratuit
    </a>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(5, 20, 38, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(34,120,224,0.2);
    padding: 10px 20px;
  }

  .nav-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .nav-logo {
    height: 44px;
    width: auto;
    object-fit: contain;
  }

  .nav-cta {
    display: inline-block;
    width: auto;
    font-size: 0.85rem;
    padding: 10px 20px;
  }
</style>
