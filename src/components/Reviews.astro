---
const reviews = [
  { name: "Khady", text: "Excellente auto-école ! Équipe très professionnelle, à l'écoute et pédagogue. Grâce à eux, j'ai obtenu mon permis du premier coup et en toute confiance. Je recommande à 100 % !" },
  { name: "Marine", text: "Auto école géniale ! Merci à Walid (moniteur) qui a su rester patient et toujours à l'écoute. Une obtention du permis avec très bon score du 1er coup 🎉 Merci à tous pour tout." },
  { name: "Océane", text: "Excellente auto-école qui se soucie de la réussite des élèves. Une équipe très humaine. Les moniteurs sont patients et à l'écoute. Je la recommande à 100% et merci pour le soutien." },
];
---
<section class="reviews">
  <div class="container">
    <span class="section-label">Témoignages</span>
    <div class="reviews-top">
      <h2 class="reviews-title">Ce que disent<br/>nos élèves</h2>
      <div class="google-badge">
        <span class="stars">★★★★★</span>
        <span>5/5 Google</span>
      </div>
    </div>

    <div class="review-list">
      {reviews.map((r) => (
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <blockquote class="review-text">"{r.text}"</blockquote>
          <div class="review-author">
            <div class="author-av">{r.name.charAt(0)}</div>
            <div>
              <span class="author-name">{r.name}</span>
              <span class="author-src">Google Maps</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews { padding: 72px 0; background: var(--bg); }

  .reviews-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 32px;
  }

  .reviews-title {
    font-size: clamp(2.2rem, 9vw, 3.5rem);
    color: var(--white);
  }

  .google-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    padding: 7px 14px;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--card-text);
    white-space: nowrap;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }

  .stars { color: #F4B942; }

  .review-list { display: flex; flex-direction: column; gap: 14px; }

  .review-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow:
      0 4px 20px rgba(0,0,0,0.15),
      0 0 16px rgba(42,126,245,0.04);
    border-radius: 8px;
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .review-stars { color: #F4B942; font-size: 1rem; letter-spacing: 2px; }

  .review-text {
    font-size: 0.93rem;
    color: var(--card-text-soft);
    line-height: 1.7;
    font-style: italic;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 12px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }

  .author-av {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--blue);
    box-shadow: 0 0 12px var(--blue-glow);
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-name { display: block; font-weight: 700; font-size: 0.88rem; color: var(--card-text); }
  .author-src { display: block; font-size: 0.75rem; color: var(--card-text-soft); }
</style>
