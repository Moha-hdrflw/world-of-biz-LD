---
const reviews = [
  {
    name: "Khady",
    stars: 5,
    text: "Excellente auto-école ! Équipe très professionnelle, à l'écoute et pédagogue. Grâce à eux, j'ai obtenu mon permis du premier coup et en toute confiance. Je recommande à 100 % !",
  },
  {
    name: "Marine",
    stars: 5,
    text: "Auto école géniale ! L'équipe est bienveillante. Merci à Walid (moniteur) qui a su rester patient et toujours à l'écoute. Malgré des moments bas, il a toujours eu les mots qu'il fallait pour me rebooster et m'encourager. Et à quel prix ? Une obtention du permis avec très bon score du 1er coup 🎉 Merci à tous pour tout.",
  },
  {
    name: "Océane",
    stars: 5,
    text: "Excellente auto-école qui se soucie de la réussite des élèves. Une équipe très humaine qui ne cherche pas juste à encaisser les élèves sans réel accompagnement. Les moniteurs sont patients et à l'écoute. Je la recommande à 100% et merci pour le soutien.",
  },
];
---
<section class="reviews">
  <div class="container">
    <span class="section-label">Témoignages</span>
    <div class="reviews-header">
      <h2 class="reviews-title">Ce que disent nos élèves</h2>
      <div class="google-rating">
        <span class="stars">★★★★★</span>
        <span class="rating-text">5/5 sur Google</span>
      </div>
    </div>

    <div class="reviews-grid">
      {reviews.map((r) => (
        <div class="review-card">
          <div class="review-stars">
            {Array.from({ length: r.stars }).map(() => <span class="star">★</span>)}
          </div>
          <blockquote class="review-text">"{r.text}"</blockquote>
          <div class="review-author">
            <div class="author-avatar">
              {r.name.charAt(0)}
            </div>
            <div class="author-info">
              <span class="author-name">{r.name}</span>
              <span class="author-source">Google Maps</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    padding: 80px 0;
    background: var(--cream);
  }

  .reviews-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 48px;
  }

  .reviews-title {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--text);
  }

  .google-rating {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--white);
    border: 1px solid var(--border);
    padding: 8px 20px;
  }

  .rating-text {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .review-card {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .review-stars {
    display: flex;
    gap: 2px;
  }

  .star {
    color: #F4B942;
    font-size: 1.1rem;
  }

  .review-text {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.65;
    font-style: italic;
    flex: 1;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .author-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--blue);
    color: var(--white);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-name {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
  }

  .author-source {
    display: block;
    font-size: 0.78rem;
    color: #888;
  }

  @media (max-width: 900px) {
    .reviews-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
      margin: 0 auto;
    }

    .reviews-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 768px) {
    .reviews {
      padding: 56px 0;
    }
  }
</style>
