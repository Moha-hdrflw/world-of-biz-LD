---
const CALENDLY = "https://calendly.com/worldofbizaxion/15min?month=2026-05";
const engagements = [
  { icon: "🚀", title: "Date d'examen express", desc: "Zéro délai d'attente. On te place à l'examen dès que tu es prêt(e) — pas de liste d'attente, pas de mois perdus." },
  { icon: "💳", title: "Paiement flexible", desc: "3x ou 4x sans frais. On s'adapte à ta situation pour que le financement ne soit jamais un obstacle." },
  { icon: "👨‍🏫", title: "Moniteurs humains & patients", desc: "Nos moniteurs sont là pour te faire progresser. Bienveillance garantie, suivi personnalisé." },
  { icon: "🏆", title: "Résultats prouvés", desc: "Des centaines d'élèves ont décroché leur permis avec nous. Un accompagnement du début à la fin, sans te laisser seul(e)." },
];
---
<section class="whyus">
  <div class="container">
    <span class="section-label">Pourquoi nous choisir ?</span>
    <h2 class="whyus-title">Nos engagements</h2>

    <div class="eng-list">
      {engagements.map((e) => (
        <div class="eng-card">
          <span class="eng-icon">{e.icon}</span>
          <h3 class="eng-title">{e.title}</h3>
          <p class="eng-desc">{e.desc}</p>
        </div>
      ))}
    </div>

    <a href={CALENDLY} target="_blank" rel="noopener noreferrer" class="btn-cta" onclick="fbq('track', 'Lead')">
      Je réserve mon appel gratuit →
    </a>
  </div>
</section>

<style>
  .whyus { padding: 72px 0; background: var(--bg-alt); }

  .whyus-title {
    font-size: clamp(2.2rem, 9vw, 3.5rem);
    color: var(--white);
    margin-bottom: 32px;
  }

  .eng-list { display: flex; flex-direction: column; gap: 14px; margin-bottom: 32px; }

  .eng-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow:
      0 4px 20px rgba(0,0,0,0.2),
      0 0 16px rgba(42,126,245,0.04);
    border-radius: 8px;
    padding: 22px;
  }

  .eng-icon { font-size: 2rem; display: block; margin-bottom: 10px; line-height: 1; }

  .eng-title {
    font-size: 1rem;
    color: var(--card-text);
    margin-bottom: 6px;
    text-transform: uppercase;
  }

  .eng-desc { font-size: 0.91rem; color: var(--card-text-soft); line-height: 1.65; }

</style>
